root = true

# Default for everything - matches the codebase's existing convention (LF,
# 4-space indents) rather than introducing a mass reformat.
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# MSBuild project/build files use 2-space indent in this repo.
[*.{csproj,props,targets,yml,yaml}]
indent_size = 2

[*.sln]
end_of_line = crlf
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[*.cs]
# Visual Studio writes UTF-8 with a BOM for .cs files in this repo; match it
# so existing files don't get flagged as changed by BOM alone.
charset = utf-8-bom

# Braces on their own line (Allman style), matching the existing codebase
# (see e.g. OWBLE.cs, OWBoard.cs) rather than K&R/"same line" style.
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true

# `using` directives: System.* first, outside the namespace block.
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:suggestion

# Prefer explicit types except where the right-hand side already makes the
# type obvious - matches the existing mixed usage rather than forcing a
# rewrite in either direction.
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Namespaces stay block-scoped: file-scoped namespaces need C# 10, newer than
# what some of this project's platform targets compile against.
csharp_style_namespace_declarations = block_scoped:suggestion

# Naming: private fields as _camelCase (see OWBLE.cs's _bluetoothGatt,
# OWBoard.cs's _owble, etc.); everything else follows the .NET defaults.
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel_case.capitalization = camel_case
dotnet_naming_style.underscore_camel_case.required_prefix = _
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel_case
dotnet_naming_rule.private_fields_underscore.severity = suggestion
