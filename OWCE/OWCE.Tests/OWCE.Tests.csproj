<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>

    <!-- OWCE.csproj -> SkiaSharp.Views.Forms 2.88.9 depends on
         Xamarin.Forms.Platform.WPF >= 4.8.0.1821 (confirmed via the actual
         NuGet restore graph on PR #43 CI, in an asset group NuGet picks for a
         net8.0 consumer specifically - OWCE.csproj's own netstandard2.1 build
         never touches it). Platform.WPF's own dependency chain is what pulls
         in OpenTK.GLControl, which has no net8.0 assets at all and trips
         NETSDK1136. Excluding OpenTK/OpenTK.GLControl directly doesn't work -
         they're two hops away from this project, and NuGet only lets a direct
         sibling reference override an inherited one for the *same,
         immediately* re-declared package. Platform.WPF is that immediate
         package, so exclude it here instead (version must match or exceed
         4.8.0.1821, or NuGet treats this as a downgrade and errors). -->
    <PackageReference Include="Xamarin.Forms.Platform.WPF" Version="4.8.0.1821" ExcludeAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\OWCE\OWCE.csproj" />
  </ItemGroup>

</Project>
