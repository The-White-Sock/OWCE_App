<Project>
  <Import Project="Sdk.props" Sdk="Microsoft.NET.Sdk" />

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\OWCE\OWCE.csproj" />
  </ItemGroup>

  <Import Project="Sdk.targets" Sdk="Microsoft.NET.Sdk" />

  <!-- Placed after the Sdk.targets import (using the explicit two-Import form
       above instead of the usual <Project Sdk="..."> shorthand specifically so
       this can go last) so it wins no matter what a transitively pulled-in
       package sets via its own build targets. OWCE.csproj -> SkiaSharp.Views.Forms
       -> OpenTK.GLControl, and OpenTK.GLControl (a WinForms control) has no
       net8.0 assets at all - NuGet falls back to its .NET Framework build (see
       the NU1701 warning in CI) - which implicitly flips UseWindowsForms/UseWPF
       on and trips the SDK's "must target -windows" check (NETSDK1136), even
       though nothing here actually uses WinForms/WPF. A plain PropertyGroup
       earlier in this file isn't enough: package .targets imports run after it
       and would just flip the flags back on. -->
  <PropertyGroup>
    <UseWindowsForms>false</UseWindowsForms>
    <UseWPF>false</UseWPF>
  </PropertyGroup>
</Project>
