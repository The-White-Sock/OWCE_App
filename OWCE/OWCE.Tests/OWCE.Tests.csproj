<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>

    <!-- Multiple packages OWCE.csproj references (SkiaSharp.Views.Forms,
         Xamarin.CommunityToolkit) transitively depend on
         Xamarin.Forms.Platform.WPF, each at a different minimum version, in
         an asset group NuGet picks for a net8.0 consumer specifically -
         OWCE.csproj's own netstandard2.1 build never touches any of this.
         Platform.WPF's own dependency chain is what pulls in
         OpenTK.GLControl, which has no net8.0 assets at all and trips
         NETSDK1136. Excluding OpenTK/OpenTK.GLControl directly doesn't work -
         they're two hops away from this project, and NuGet only lets a
         direct sibling reference override an inherited one for the *same,
         immediately* re-declared package. Platform.WPF is that immediate
         package, so exclude it here instead. Pinned to the same version as
         OWCE.csproj's own Xamarin.Forms reference below - Platform.WPF is
         published in lockstep with the main Xamarin.Forms package, so this
         is comfortably above every transitive minimum seen so far (4.8.0.1821,
         5.0.0.2291) without needing to track each one individually. -->
    <PackageReference Include="Xamarin.Forms.Platform.WPF" Version="5.0.0.2662" ExcludeAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\OWCE\OWCE.csproj" />
  </ItemGroup>

</Project>
